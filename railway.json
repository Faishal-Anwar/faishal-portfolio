{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": {
      "providers": ["php", "node"],
      "buildCmds": [
        "composer install --no-dev --optimize-autoloader",
        "npm install",
        "npm run build"
      ]
    }
  },
  "deploy": {
    "releaseCommand": "php artisan migrate --force",
    "healthcheckPath": "/",
    "healthcheckTimeout": 120
  }
}
