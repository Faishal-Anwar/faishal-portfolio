{
    "version": 2,
    "builds": [
        {
            "src": "public/index.php",
            "use": "vercel-php@0.7.4"
        }
    ],
    "outputDirectory": "public",
    "routes": [
        {
            "src": "/build/(.*)",
            "headers": { "cache-control": "public, max-age=31536000, immutable" },
            "dest": "/public/build/$1"
        },
        {
            "src": "/assets/(.*)",
            "headers": { "cache-control": "public, max-age=31536000, immutable" },
            "dest": "/public/assets/$1"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/(.*)",
            "dest": "/public/index.php"
        }
    ],
    "env": {
        "APP_NAME": "Portfolio Faishal",
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_URL": "https://faishal-portfolio.vercel.app",
        "APP_KEY": "base64:667PJgX9TmOkB5BGVWwoBoMUBHO2kFe4quCTWR93vAY=",
        
        "LOG_CHANNEL": "stderr",
        "DB_CONNECTION": "mysql",
        "DB_HOST": "db-portfolio-faishal-anwar.c.aivencloud.com",
        "DB_PORT": "21931",
        "DB_DATABASE": "defaultdb",
        "DB_USERNAME": "avnadmin",

        "CACHE_STORE": "file",
        "QUEUE_CONNECTION": "sync",
        "SESSION_DRIVER": "cookie",
        "SESSION_LIFETIME": "120",

        "MAIL_MAILER": "smtp",
        "MAIL_HOST": "smtp.gmail.com",
